# Copy to .env and fill in values. Never commit .env.
# Run ./scripts/setup-neon-env.sh dev to populate DATABASE_URL automatically.

# Neon (run scripts/setup-neon-env.sh)
DATABASE_URL=
NEON_ORG_ID=org-flat-fire-88103782
NEON_PROJECT_ID=patient-sunset-77985570
NEON_BRANCH=dev

# Apify supplement layer (Apify Browser + HTTP actors)
APIFY_API_TOKEN=
APIFY_USER_ID=
# When true (default if token set), ESPN JSON feeds use apify/playwright-scraper browser pool
APIFY_BROWSER_ENABLED=true

# Paid data providers (sign up per documentation/data-source-research.md)
THE_ODDS_API_KEY=
SPORTSDATAIO_API_KEY=
OPENWEATHERMAP_API_KEY=
PFF_API_KEY=

# Keys below activate automatically when set — jobs skip cleanly when empty
